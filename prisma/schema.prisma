generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id          String   @id @default(uuid())
  username    String   @unique
  password    String
  role        Role
  level       Level?
  name        String
  email       String?
  classRoomId String?
  classRoom   ClassRoom? @relation(fields: [classRoomId], references: [id])
  attempts    ExamAttempt[]
  createdSubjects   Subject[]  @relation("SubjectCreator")
  accessibleSubjects Subject[] @relation("SubjectSharedWith")
  createdExams      Exam[]     @relation("ExamCreator")
  accessibleExams   Exam[]     @relation("ExamSharedWith")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @default(now()) @updatedAt
}

model SystemSetting {
  id          String   @id @default("global")
  schoolName  String   @default("Tabgha Academic")
  activeTerm  Term     @default(UTS_1)
  updatedAt   DateTime @default(now()) @updatedAt
}

model ClassRoom {
  id          String   @id @default(uuid())
  level       Level
  grade       Int
  name        String
  createdAt   DateTime @default(now())
  students    User[]
  exams       Exam[]   @relation("ExamClassRooms")
}

model Subject {
  id          String     @id @default(uuid())
  name        String
  level       Level
  createdById String?
  createdBy   User?      @relation("SubjectCreator", fields: [createdById], references: [id], onDelete: SetNull)
  sharedWith  User[]     @relation("SubjectSharedWith")
  questions   Question[]
  exams       Exam[]
}

model Question {
  id        String   @id @default(uuid())
  text      String   @db.Text
  type      QuestionType @default(MULTIPLE_CHOICE)
  mediaUrl  String?  @db.Text
  mediaType String?  // e.g., 'image' or 'video'
  subjectId String
  subject   Subject  @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  options   Json?    // Array of { id: string, text: string, isCorrect: boolean, mediaUrl?: string }
  createdAt DateTime @default(now())
}

model Exam {
  id          String   @id @default(uuid())
  title       String
  term        Term
  level       Level
  classRooms  ClassRoom[] @relation("ExamClassRooms")
  subjectId   String
  subject     Subject  @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  durationMin Int
  status      String   @default("DRAFT")
  createdById String?
  createdBy   User?    @relation("ExamCreator", fields: [createdById], references: [id], onDelete: SetNull)
  sharedWith  User[]   @relation("ExamSharedWith")
  attempts    ExamAttempt[]
  createdAt   DateTime @default(now())
}

model ExamAttempt {
  id         String   @id @default(uuid())
  studentId  String
  examId     String
  startTime  DateTime
  endTime    DateTime?
  score      Float?
  isCheated  Boolean  @default(false)
  cheatLogs  CheatLog[]
  student    User     @relation(fields: [studentId], references: [id])
  exam       Exam     @relation(fields: [examId], references: [id], onDelete: Cascade)
}

model CheatLog {
  id          String   @id @default(uuid())
  attemptId   String
  eventType   String
  timestamp   DateTime @default(now())
  attempt     ExamAttempt @relation(fields: [attemptId], references: [id])
}

enum Role { 
  ADMIN 
  TEACHER 
  STUDENT 
}

enum Level { 
  SD 
  SMP 
  SMA 
  SMK 
}

enum Term { 
  UTS_1 
  SEM_1 
  UTS_2 
  SEM_2 
}

enum QuestionType {
  MULTIPLE_CHOICE
  ESSAY
}
